# ── Qdrant ────────────────────────────────────────
# For Qdrant Cloud:
#   QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
#   QDRANT_API_KEY=your_api_key
#
# For local Qdrant (via Docker profile):
#   QDRANT_URL=http://qdrant:6333
#   QDRANT_API_KEY=          (leave empty)

QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_COLLECTION=documents

# ── LLM Provider ──────────────────────────────────
# Options: "ollama" or "deepseek"
LLM_PROVIDER=ollama

# ── Ollama (local) ────────────────────────────────
# If running outside Docker:  http://localhost:11434
# If running inside Docker:   http://host.docker.internal:11434
# (docker-compose overrides this automatically)
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# ── DeepSeek (cloud) ──────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat
